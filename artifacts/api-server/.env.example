# ── Stride API Server — Environment Variables ─────────────────────────────────
# Copy this file to .env (never commit .env to git).
# In Replit, set these as Secrets (the padlock icon in the sidebar).

# ── Database ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Auth ──────────────────────────────────────────────────────────────────────
SESSION_SECRET=a-long-random-string-at-least-32-chars

# ── Stripe (payments) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: default price ID used when no per-org price is set
STRIPE_PRICE_ID_PER_SEAT=price_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up free at https://resend.com → API Keys → Create API Key
# Paste the key (starts with re_) below.
# Without this key the system still runs: emails are logged to the console
# instead of being sent, so development works without any setup.
RESEND_API_KEY=re_...

# The "From" address shown in delivered emails.
# Must be a verified domain or the Resend sandbox address.
# Sandbox (free tier, delivers only to your own email): onboarding@resend.dev
RESEND_FROM_EMAIL=Stride <billing@yourdomain.com>

# ── App URL (used in email links) ─────────────────────────────────────────────
# Set to your production domain once deployed.
# In development Replit sets REPLIT_DEV_DOMAIN automatically.
STRIDE_APP_URL=https://yourdomain.com

# ── GitHub (optional — import integration) ────────────────────────────────────
GITHUB_PAT=ghp_...
